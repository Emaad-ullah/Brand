# Environment Variables Example
# Duplicate this file to .env and fill in your details

# Application Environment (development, production)
VITE_APP_ENV=development

# Base URL for API
# When deploying to Vercel, this can be empty or set to your production API URL
VITE_API_BASE_URL=/api

# Add any additional API keys or sensitive configurations here
# e.g., VITE_STRIPE_PUBLIC_KEY=pk_test_12345
